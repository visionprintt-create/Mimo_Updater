rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        getUserData().role in ['founder', 'co-founder', 'hr', 'admin'];
    }

    // ─── Users Collection ────────────────────────────────────
    match /users/{userId} {
      // All authenticated users can read profiles (interns need this to view teammates)
      allow read: if isAuthenticated();
      
      // Users can create their own profile on registration
      allow create: if isOwner(userId);
      
      // Only admins can update user status (approve/reject/suspend)
      // Users can update their own non-critical fields
      allow update: if isAdmin() || 
        (isOwner(userId) && 
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['status', 'role', 'approvedBy', 'approvedAt']));
           
      allow delete: if isAdmin();
    }

    // ─── Sessions Collection ─────────────────────────────────
    match /sessions/{sessionId} {
      // All authenticated users can read all sessions (interns can see team-wide history)
      allow read: if isAuthenticated();
      
      // Users can create their own sessions
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // Users can update their own active sessions (clock out, add tasks)
      // Admins can update any session (for reviews/remarks)
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
        
      allow delete: if isAdmin();
    }

    // ─── Weekly Tasks Collection ─────────────────────────────
    match /weekly_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ─── Leaves Collection ───────────────────────────────────
    match /leaves/{leaveId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin() || (isOwner(resource.data.userId) && resource.data.status == 'pending');
    }

    // ─── Invitations Collection ──────────────────────────────
    match /invitations/{email} {
      // Admins can create, read, update, delete invitations
      allow read, write: if isAdmin();
      // Unauthenticated users cannot read invitations (they must sign in first)
      // But wait, when they sign in with Google, they ARE authenticated.
      // So any authenticated user can read their own invitation by email.
      allow read, delete: if isAuthenticated() && request.auth.token.email == email;
    }

    // ─── Audit Logs Collection ───────────────────────────────
    match /audit_logs/{logId} {
      // Any authenticated user can create an audit log (e.g. for session starts)
      allow create: if isAuthenticated();
      // Only admins can read audit logs
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ─── Notifications Collection ────────────────────────────
    match /notifications/{notifId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // Admins can create notifications for any user
      // System can create notifications (via user's own session actions)
      allow create: if isAuthenticated();
      
      // Users can mark their own notifications as read
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
        
      allow delete: if isAdmin();
    }
  }
}
